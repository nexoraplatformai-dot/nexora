{
  "name": "nexora",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "googleapis": "^126.0.1",
    "twilio": "^4.19.0",
    "@sendgrid/mail": "^7.7.0"
  }
}
  {
  "triggers": [
    {
      "type": "calendar_event",
      "calendar": "google",
      "keywords": ["visite"],
      "delay": 0
    },
    {
      "type": "form_submission",
      "form_id": "lead-form",
      "webhook_url": null
    },
    {
      "type": "whatsapp_message",
      "keyword": "rdv",
      "action": "parse_appointment"
    }
  ],
  "actions": [
    {
      "type": "sms",
      "to": "client",
      "delay": -1,
      "template": "rappel_j1",
      "params": ["{prenom}", "{date}", "{heure}"]
    },
    {
      "type": "email",
      "to": "agent",
      "template": "nouveau_lead",
      "subject": "Nouveau lead qualifié"
    },
    {
      "type": "whatsapp",
      "to": "client",
      "delay": -2,
      "template": "confirmation_rdv",
      "buttons": true
    },
    {
      "type": "calendar_event",
      "summary": "Rendez-vous",
      "description": "{description}",
      "duration": 60
    },
    {
      "type": "webhook",
      "url": "https://api.example.com/hook",
      "method": "POST"
    },
    {
      "type": "ai_analysis",
      "model": "gpt-4",
      "prompt": "Analyser le message et extraire les informations"
    },
    {
      "type": "voice_call",
      "to": "client",
      "twiml": "<Say>Bonjour, ceci est un rappel...</Say>"
    }
  ],
  "conditions": [
    { "field": "lead_score", "operator": ">", "value": 80 },
    { "field": "budget", "operator": ">=", "value": 200000 },
    { "field": "day_of_week", "operator": "in", "value": ["Monday", "Wednesday"] }
  ],
  "culture": {
    "language": "fr",
    "tone": "chaleureux",
    "region": "wallonie"
  }
}
